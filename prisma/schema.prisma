generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models (NextAuth) ─────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────
model User {
  id              String      @id @default(cuid())
  name            String?
  username        String?     @unique
  email           String?     @unique
  password        String?
  emailVerified   DateTime?
  image           String?
  role            String      @default("TEAM_MEMBER") // SUPER_ADMIN, AGENCY_OWNER, TEAM_MEMBER
  isApproved      Boolean     @default(true)
  
  // AI API Keys
  anthropicApiKey String?
  openaiApiKey    String?
  geminiApiKey    String?

  defaultAiContentProvider String @default("CLAUDE")
  defaultAiImageProvider   String @default("DALL-E-3")

  // Custom Model IDs
  anthropicModel      String @default("claude-3-5-sonnet-20241022")
  openaiContentModel  String @default("gpt-4o")
  openaiImageModel    String @default("dall-e-3")
  geminiContentModel  String @default("gemini-1.5-flash")
  geminiImageModel    String @default("imagen-3.0-generate-001")
  
  // Hierarchy
  ownerId         String?
  owner           User?       @relation("TeamMembers", fields: [ownerId], references: [id])
  teamMembers     User[]      @relation("TeamMembers")

  // Permissions (primarily for TEAM_MEMBER)
  canPublishNow   Boolean     @default(true)
  canSchedule     Boolean     @default(true)
  minScheduleDays Int         @default(0)

  // Assigned Profiles
  assignedLocations Location[] @relation("LocationAssignments")

  accounts        Account[]
  sessions        Session[]
  clients         Client[]
  posts           Post[]
  apiKeys         ApiKey[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Client {
  id          String     @id @default(cuid())
  name        String
  description String?
  website     String?
  logo        String?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations   Location[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
}

model Location {
  id            String   @id @default(cuid())
  name          String
  address       String?
  phone         String?
  gbpAccountId  String   // Google Business Account ID
  gbpLocationId String   // Google Business Location ID
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  posts         Post[]
  assignedUsers User[] @relation("LocationAssignments")

  // AI Configuration
  aiInstructions         String?   @db.Text
  aiKeywords             String?   @db.Text
  aiTone                 String?
  aiCompetitorData       String?   @db.Text
  aiKeywordSequence      String?   @db.Text   // Comma-separated or JSON list
  aiCurrentSequenceIndex Int       @default(0)
  
  aiContentProvider      String    @default("DEFAULT") // CLAUDE, GPT, GEMINI
  aiImageProvider        String    @default("DEFAULT") // DALL-E-3
  aiImageEnabled         Boolean   @default(true)
  
  aiWebsite              String?
  aiPhone                String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([gbpAccountId, gbpLocationId])
  @@index([clientId])
}

model Post {
  id              String      @id @default(cuid())
  title           String?
  summary         String
  topicType       String      @default("STANDARD")
  ctaType         String?
  ctaUrl          String?
  mediaUrl        String?
  mediaType       String?
  status          String      @default("DRAFT")
  scheduledAt     DateTime?
  publishedAt     DateTime?
  gbpPostId       String?     // GBP post ID after publishing
  gbpPostName     String?     // Full GBP resource name: accounts/.../localPosts/...
  errorMessage    String?
  failureReason   String?     // Human-readable failure reason
  retryCount      Int         @default(0)
  maxRetries      Int         @default(3)

  // Relations
  locationId      String
  location        Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Event fields (optional)
  eventTitle      String?
  eventStartDate  DateTime?
  eventEndDate    DateTime?

  // Offer fields (optional)
  offerCouponCode String?
  offerRedeemUrl  String?
  offerTerms      String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status, scheduledAt])
  @@index([locationId])
  @@index([userId])
}

// ─── API Keys (for n8n / external integrations) ──────────
model ApiKey {
  id          String    @id @default(cuid())
  label       String                          // e.g. "n8n Production"
  keyHash     String    @unique               // SHA-256 of the raw key (never store raw)
  keyPrefix   String                          // First 8 chars for display: "rvk_abc1..."
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes      String    @default("posts:write,profiles:read")  // comma-separated
  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
}
model GlobalSetting {
  id               String   @id @default("settings")
  loginBgUrl       String   @default("/login-bg.jpg")
  loginHeading     String   @default("Your Google Business, Managed in One Place.")
  loginDescription String   @default("Connect your Google account and manage all your business profiles from a single dashboard.")
  loginBgOpacity   Float    @default(0.5)
  updatedAt        DateTime @updatedAt
}
