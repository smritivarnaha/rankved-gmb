generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth Models (NextAuth) ─────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Core Models ────────────────────────────────────────
model User {
  id              String      @id @default(cuid())
  name            String?
  username        String?     @unique
  email           String?     @unique
  password        String?
  emailVerified   DateTime?
  image           String?
  role            String      @default("TEAM_MEMBER") // SUPER_ADMIN, AGENCY_OWNER, TEAM_MEMBER
  isApproved      Boolean     @default(true)
  
  // AI API Keys
  anthropicApiKey  String?
  openaiApiKey     String?
  geminiApiKey     String?
  openrouterApiKey String?

  defaultAiContentProvider String @default("CLAUDE")
  defaultAiImageProvider   String @default("DALL-E-3")

  // Custom Model IDs
  anthropicModel      String @default("claude-3-5-sonnet-20241022")
  openaiContentModel  String @default("gpt-4o")
  openaiImageModel    String @default("dall-e-3")
  geminiContentModel  String @default("gemini-1.5-flash")
  geminiImageModel    String @default("imagen-3.0-generate-001")
  openrouterModel     String @default("openrouter/auto")
  
  // Hierarchy
  ownerId         String?
  owner           User?       @relation("TeamMembers", fields: [ownerId], references: [id])
  teamMembers     User[]      @relation("TeamMembers")

  // Permissions (primarily for TEAM_MEMBER)
  canPublishNow   Boolean     @default(true)
  canSchedule     Boolean     @default(true)
  minScheduleDays Int         @default(0)

  // Assigned Profiles
  assignedLocations Location[] @relation("LocationAssignments")

  accounts        Account[]
  sessions        Session[]
  clients         Client[]
  posts           Post[]
  apiKeys         ApiKey[]
  prompts         PromptTemplate[]
  notifications   Notification[]
  
  // SMM Fields
  smmAssignedClients Client[]    @relation("SmmClientAssignments")
  smmPosts           SmmPost[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model Client {
  id          String     @id @default(cuid())
  name        String
  description String?
  website     String?
  logo        String?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  locations   Location[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // SMM Fields
  businessClinicName String?
  contactPerson      String?
  email              String?
  phone              String?
  status             String     @default("ACTIVE") // ACTIVE, INACTIVE
  smmAssignedUsers   User[]     @relation("SmmClientAssignments")
  socialAccounts     SocialAccount[]
  mediaAssets        MediaAsset[]
  smmPosts           SmmPost[]
  approvalGroups     SmmApprovalGroup[]

  @@index([userId])
}

model Location {
  id            String   @id @default(cuid())
  name          String
  address       String?
  phone         String?
  gbpAccountId  String   // Google Business Account ID
  gbpLocationId String   // Google Business Location ID
  clientId      String
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  posts         Post[]
  notifications Notification[]
  assignedUsers User[] @relation("LocationAssignments")

  // AI Configuration
  aiInstructions         String?   @db.Text
  aiKeywords             String?   @db.Text
  aiTone                 String?
  aiCompetitorData       String?   @db.Text
  aiKeywordSequence      String?   @db.Text   // Comma-separated or JSON list
  aiCurrentSequenceIndex Int       @default(0)
  
  aiContentProvider      String    @default("DEFAULT") // CLAUDE, GPT, GEMINI
  aiImageProvider        String    @default("DEFAULT") // DALL-E-3
  aiImageEnabled         Boolean   @default(true)
  
  aiWebsite              String?
  aiPhone                String?
  aiImageInstructions    String?   @db.Text
  logoUrl                String?   // GBP profile/logo photo URL (fetched during sync)
  googleEmail            String?   // The email of the connected Google account
  
  // Cached Performance Stats
  cachedSearchViews      Int       @default(0)
  cachedInteractions     Int       @default(0)
  cachedEngagements      Int       @default(0)
  statsUpdatedAt         DateTime?
  
  isHidden               Boolean   @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([gbpAccountId, gbpLocationId])
  @@index([clientId])
}

model Post {
  id              String      @id @default(cuid())
  title           String?
  summary         String
  topicType       String      @default("STANDARD")
  focusKeyword    String?
  ctaType         String?
  ctaUrl          String?
  mediaUrl        String?
  mediaType       String?
  status          String      @default("DRAFT")
  scheduledAt     DateTime?
  publishedAt     DateTime?
  gbpPostId       String?     // GBP post ID after publishing
  gbpPostName     String?     // Full GBP resource name: accounts/.../localPosts/...
  errorMessage    String?
  failureReason   String?     // Human-readable failure reason
  retryCount      Int         @default(0)
  maxRetries      Int         @default(3)

  // Relations
  locationId      String
  location        Location    @relation(fields: [locationId], references: [id], onDelete: Cascade)
  userId          String
  user            User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Event fields (optional)
  eventTitle      String?
  eventStartDate  DateTime?
  eventEndDate    DateTime?

  // Offer fields (optional)
  offerCouponCode String?
  offerRedeemUrl  String?
  offerTerms      String?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status, scheduledAt])
  @@index([locationId])
  @@index([userId])
}

// ─── API Keys (for n8n / external integrations) ──────────
model ApiKey {
  id          String    @id @default(cuid())
  label       String                          // e.g. "n8n Production"
  keyHash     String    @unique               // SHA-256 of the raw key (never store raw)
  keyPrefix   String                          // First 8 chars for display: "rvk_abc1..."
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  scopes      String    @default("posts:write,profiles:read")  // comma-separated
  lastUsedAt  DateTime?
  usageCount  Int       @default(0)
  isActive    Boolean   @default(true)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
}
model GlobalSetting {
  id               String   @id @default("settings")
  loginBgUrl       String   @default("/login-bg.jpg")
  loginHeading     String   @default("Your Google Business, Managed in One Place.")
  loginDescription String   @default("Connect your Google account and manage all your business profiles from a single dashboard.")
  loginBgOpacity   Float    @default(0.5)
  aiFeaturesEnabled Boolean @default(false)
  
  // Dashboard Branding
  sidebarLogoUrl   String   @default("https://rankved.com/wp-content/uploads/2025/04/Rankved-Logo-Official-Black.avif")
  sidebarText      String   @default("RankVed")
  sidebarLogoShape String   @default("circle") // circle, square, rounded
  sidebarLogoSize  Int      @default(24)
  sidebarTextSize  Int      @default(14)
  
  // Notification Settings
  notificationEmails        String  @default("rankved.business@gmail.com")
  notificationCcEmails      String  @default("")
  successTemplateSubject    String  @default("✅ Post Published: {profileName} - {postPreview}")
  successTemplateBody       String  @default("Your post has been published successfully.\n\nProfile: {profileName}\nPost: {postSummary}")
  failureTemplateSubject    String  @default("⚠️ Post Failed: {profileName}")
  failureTemplateBody       String  @default("Your post failed to publish.\n\nProfile: {profileName}\nError: {error}\nPost: {postSummary}")
  scheduledTemplateSubject  String  @default("🕒 Post Scheduled: {profileName}")
  scheduledTemplateBody     String  @default("A new post has been scheduled.\n\nProfile: {profileName}\nDate: {scheduledAt}")

  // GBP Intelligence Monitoring
  monitoringEnabled         Boolean @default(true)
  reviewAlertsEnabled       Boolean @default(true)
  performanceAlertsEnabled  Boolean @default(true)
  callsSpikeThreshold       Int     @default(20)   // % increase week-over-week
  directionsSpikeThreshold  Int     @default(20)
  clicksSpikeThreshold      Int     @default(15)
  
  updatedAt        DateTime @updatedAt
}

model PromptTemplate {
  id        String   @id @default(cuid())
  title     String
  content   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Backup {
  id        String   @id @default(cuid())
  name      String
  data      Json
  createdAt DateTime @default(now())
}

model Notification {
  id          String   @id @default(cuid())
  type        String   @default("INTERNAL") // INTERNAL (system), EXTERNAL (customer)
  title       String
  message     String   @db.Text
  isRead      Boolean  @default(false)
  actionUrl   String?
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  locationId  String?
  location    Location? @relation(fields: [locationId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, isRead])
  @@index([locationId])
}

// ─── GBP Review Snapshots ─────────────────────────────────
// Stores the last known review state per location to detect new reviews
model ReviewSnapshot {
  id               String   @id @default(cuid())
  locationId       String   @unique
  totalReviewCount Int      @default(0)
  averageRating    Float    @default(0)
  lastReviewIds    String   @default("") @db.Text  // JSON array of last seen review names
  
  // Performance baseline (last week's metrics for spike detection)
  lastCallCount        Int @default(0)
  lastDirectionCount   Int @default(0)
  lastClickCount       Int @default(0)
  lastCheckedAt        DateTime @default(now())
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([locationId])
}

// ─── Social Media Management (SMM) Models ──────────────────
model SocialAccount {
  id             String   @id @default(cuid())
  clientId       String
  client         Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  platform       String   // FACEBOOK, INSTAGRAM, LINKEDIN
  accountId      String   // Facebook Page ID, Instagram Account ID, LinkedIn Org ID
  accountName    String   // e.g. "Dr Prince Arthro Care Page"
  accessToken    String?  // encrypted access token
  status         String   @default("CONNECTED") // CONNECTED, DISCONNECTED, EXPIRED
  avatarUrl      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  posts          SmmPostDestination[]

  @@unique([platform, accountId])
  @@index([clientId])
}

model MediaAsset {
  id         String   @id @default(cuid())
  clientId   String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name       String
  url        String
  type       String   // IMAGE, VIDEO, DOCUMENT
  sizeBytes  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([clientId])
}

model SmmApprovalGroup {
  id          String    @id @default(cuid())
  clientId    String
  client      Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String    // e.g. "Week 1 Content Approval"
  secureToken String    @unique // The xyz123 token used in the link
  status      String    @default("PENDING") // PENDING, APPROVED, REJECTED, PARTIALLY_APPROVED
  posts       SmmPost[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
}

model SmmPost {
  id              String         @id @default(cuid())
  clientId        String
  client          Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  caption         String         @db.Text
  hashtags        String?        @db.Text
  internalNotes   String?        @db.Text
  mediaUrls       String[]       // Array of media URLs associated with the post
  status          String         @default("DRAFT") // DRAFT, REVIEW, PENDING_APPROVAL, APPROVED, REJECTED, SCHEDULED, PUBLISHED, FAILED
  scheduledAt     DateTime?
  publishedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  approvalGroupId String?
  approvalGroup   SmmApprovalGroup? @relation(fields: [approvalGroupId], references: [id], onDelete: SetNull)
  
  destinations    SmmPostDestination[]
  history         SmmApprovalHistory[]

  @@index([clientId])
  @@index([status])
  @@index([scheduledAt])
}

model SmmPostDestination {
  id              String        @id @default(cuid())
  postId          String
  post            SmmPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  socialAccountId String
  socialAccount   SocialAccount @relation(fields: [socialAccountId], references: [id], onDelete: Cascade)
  status          String        @default("PENDING") // PENDING, PUBLISHED, FAILED
  publishedAt     DateTime?
  externalPostId  String?       // ID returned by the platform's API
  errorMessage    String?       @db.Text
  apiResponse     String?       @db.Text
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([postId, socialAccountId])
}

model SmmApprovalHistory {
  id        String   @id @default(cuid())
  postId    String
  post      SmmPost  @relation(fields: [postId], references: [id], onDelete: Cascade)
  action    String   // APPROVE, REJECT, REQUEST_CHANGES
  actor     String   // "CLIENT" or User Name / User Email
  comments  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([postId])
}

